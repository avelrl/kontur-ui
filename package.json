{
  "name": "kontur-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist/theme",
    "README.md",
    "README.ru.md",
    "LICENSE"
  ],
  "exports": {
    "./theme": {
      "types": "./dist/theme/kontur-theme.d.ts",
      "import": "./dist/theme/kontur-theme.js"
    },
    "./theme.css": "./dist/theme/theme.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:demo && npm run build:theme",
    "build:demo": "tsc -p tsconfig.app.json && vite build",
    "build:theme": "npm run build:theme:js && npm run build:theme:types && npm run build:theme:styles",
    "build:theme:js": "vite build --config vite.theme.config.ts",
    "build:theme:types": "tsc -p tsconfig.theme.json",
    "build:theme:styles": "node scripts/copy-theme-css.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
